{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "strict": true,
    "lib": ["dom", "dom.iterable", "es2022"],
    "types": ["chrome", "node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"]
}